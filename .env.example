TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# Provider LLM — pilih salah satu:
LLM_PROVIDER=claude
# LLM_PROVIDER=groq

# --- Claude (Anthropic) https://console.anthropic.com/ ---
ANTHROPIC_API_KEY=
# Pilih salah satu model (uncomment 1 baris):
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-opus-4-20250514
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_BASE_URL=   # optional proxy

# --- Groq (fallback gratis) https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback

# PostgreSQL (Railway Postgres atau Docker lokal)
# Contoh lokal: postgresql://postgres:postgres@localhost:5432/budakcv
# Railway: pakai DATABASE_URL dari Postgres addon
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Opsional: bootstrap token Gmail sekali (JSON dari output gmail:auth)
# GMAIL_TOKEN_JSON=

MAX_EMAILS_PER_DAY=10
