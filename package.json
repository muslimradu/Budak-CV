{
  "name": "bot-tele-gmail",
  "version": "1.0.0",
  "description": "Personal Telegram bot for job applications via Gmail",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma migrate deploy && tsx src/index.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "gmail:auth": "tsx src/gmail/oauth-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@prisma/client": "^6.10.1",
    "dotenv": "^16.5.0",
    "googleapis": "^150.0.1",
    "grammy": "^1.36.1",
    "openai": "^6.46.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
